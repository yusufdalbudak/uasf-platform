# =============================================================================
# UASF backend — production environment template
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit the resulting `.env`.
# For local Docker development the values in `docker-compose.yml` already wire
# most of these up; this file documents what a standalone (cloud) deployment
# needs.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
SERVICE_NAME=UASF — Universal Attack Simulation Framework
SERVICE_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Infrastructure dependencies (REQUIRED)
# -----------------------------------------------------------------------------
# Full PostgreSQL URL (TypeORM will pool connections against it).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/waap_platform

# Redis powers BullMQ queues + the assessment worker. Both host and port are
# required; there is no fallback because the worker is not optional.
REDIS_HOST=REDIS_HOST_REPLACE_ME
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Policy / safety (REQUIRED)
# -----------------------------------------------------------------------------
# Comma-separated list of hostnames and AppTrana-style labels that may receive
# outbound validation traffic. The backend refuses to dispatch scans to
# anything not on this list.
ALLOWED_TARGETS=example.com,api.example.com

# Hard caps on worker parallelism and request rate. Keep low unless you have
# explicit approval from the target owners.
SAFETY_MAX_CONCURRENCY=5
SAFETY_MAX_RPS=50

# Executable workflows require a matching approved row in the asset registry.
# Leave at `true` in production.
REQUIRE_REGISTERED_ASSET=true

# TypeORM `synchronize` — leave unset or `false` in production; use migrations.
DB_SYNCHRONIZE=false

# -----------------------------------------------------------------------------
# Authentication / cookies (REQUIRED in production)
# -----------------------------------------------------------------------------
# Frontend origin(s) allowed by CORS. Comma-separated list is supported for
# production + preview URLs. REQUIRED in production — the backend fails to
# boot without this set.
#   FRONTEND_ORIGIN=https://uasf.example.com,https://uasf-preview.vercel.app
FRONTEND_ORIGIN=https://uasf.example.com

# HMAC secret for short-lived access JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_48_BYTE_HEX

# Server-side pepper folded into refresh-token hashes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REFRESH_TOKEN_PEPPER=REPLACE_WITH_32_BYTE_HEX

# Token TTLs (seconds). Defaults: access=15min, refresh=14d.
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=1209600

# Cookie security. MUST be `true` when frontend runs over HTTPS (always in
# production). The refresh cookie is automatically upgraded to
# `SameSite=None` when `COOKIE_SECURE=true`, which is required for split
# (Vercel frontend + separate-host backend) deployments.
COOKIE_SECURE=true

# Optional explicit override for the refresh cookie's SameSite attribute:
# `none` | `lax` | `strict`. Leave unset to use the automatic value above.
#COOKIE_SAMESITE=none

# Hard gate: keep at `true` for any shared/public deployment.
AUTH_REQUIRED=true

# Email verification flow. Leave `false` unless you have wired an SMTP relay.
REQUIRE_EMAIL_VERIFICATION=false

# Login lockout policy.
LOGIN_LOCKOUT_SEC=900
LOGIN_MAX_FAILED_ATTEMPTS=8

# Privacy policy version the signup form displays. Bump when policy changes.
PRIVACY_POLICY_VERSION=2026-04-19

# Optional one-shot bootstrap of the first admin account. Both must be set for
# bootstrap to run (idempotent: skipped if any user already exists).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Optional third-party intelligence (unset = providers reported "not configured")
# -----------------------------------------------------------------------------
VIRUSTOTAL_API_KEY=
ABUSE_CH_AUTH_KEY=
