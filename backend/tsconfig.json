{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "..",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["es2022", "DOM"]
  },
  "include": ["src/**/*", "../shared/**/*"]
}
